# ============================================================
# ResearchForge 智能研究工坊 - 配置模板
# ============================================================
# 使用方法：
#   1. 复制此文件为 .env
#   2. 填入你的 API Key
#   3. 按需调整其他配置
#
#   cp .env.example .env
# ============================================================

# ==================== 必需配置 ====================

# 百炼平台（DashScope）API 密钥
# 获取：https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-api-key-here

# LLM 提供者：bailian | ollama
LLM_PROVIDER=bailian

# 使用的模型（百炼上署名的模型名，如 kimi-k2.6）
RESEARCHFORGE_MODEL=kimi-k2.6

# API 端点（默认 DashScope 兼容模式）
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# LLM 超时时间（秒，k2.6 推理慢建议 600）
LLM_TIMEOUT=600

# ==================== 服务配置 ====================

# 监听地址
# HOST=0.0.0.0

# 监听端口
# PORT=8002

# 调试模式
# DEBUG=false

# ==================== 限流配置 ====================

# 每分钟最大请求数
# RATE_LIMIT_MAX=20

# 限流窗口（秒）
# RATE_LIMIT_WINDOW=60

# ==================== 记忆系统 ====================

# Buffer 记忆最大 Token
# MEMORY_BUFFER_MAX_TOKENS=4000

# Summary 记忆最大 Token
# MEMORY_SUMMARY_MAX_TOKENS=2000

# RAG 记忆 Top-K
# MEMORY_RAG_TOP_K=3

# ==================== 研究配置 ====================

# Planner 最大步骤数
# PLANNER_MAX_STEPS=5

# GroupChat 最大轮次
# GROUPCHAT_MAX_ROUNDS=6

# ReAct Agent 最大步数
# REACT_MAX_STEPS=5

# ReAct Agent 最大重新规划次数
# REACT_MAX_REPLANS=2
